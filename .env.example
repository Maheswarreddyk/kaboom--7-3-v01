# ==========================================
# Vercel Serverless API (set in Vercel Dashboard)
# ==========================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Custom STUN servers (comma-separated)
# STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# ==========================================
# Frontend (set in Vercel Dashboard — Build & Runtime)
# VITE_* vars are embedded at build time
# ==========================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Leave empty on Vercel (uses same-origin /api routes)
# For local dev with vercel dev, also leave empty
VITE_API_URL=
