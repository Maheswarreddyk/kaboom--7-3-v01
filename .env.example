# ==========================================
# IndiaTV Environment Configuration
# Copy to .env for local development
# ==========================================

# Environment: development | staging | production | test
NODE_ENV=development
VITE_APP_ENV=development

# ==========================================
# Supabase (required)
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend build-time (VITE_* embedded at build)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# ==========================================
# API & Signaling
# ==========================================
# Leave empty on Vercel (same-origin /api)
VITE_API_URL=

# Signaling: supabase (default) | socketio
VITE_SIGNALING_PROVIDER=supabase

# Socket.IO URL (only when VITE_SIGNALING_PROVIDER=socketio)
# Leave empty to use same origin
VITE_SOCKET_URL=

# Backend
PORT=5000
FRONTEND_URL=http://localhost:5173

# ==========================================
# WebRTC
# ==========================================
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# TURN_SERVERS=turn:your-turn-server:3478
# TURN_USERNAME=
# TURN_CREDENTIAL=

# ==========================================
# Admin (optional)
# ==========================================
ADMIN_TOKEN=your-secure-admin-token
